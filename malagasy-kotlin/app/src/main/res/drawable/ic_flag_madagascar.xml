<!-- Madagascar flag as vector drawable for Android app icon -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- White left stripe (1/3 width) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M0,0 h36 v108 h-36 z" />
    
    <!-- Red top right (2/3 width, top half) -->
    <path
        android:fillColor="#E32139"
        android:pathData="M36,0 h72 v54 h-72 z" />
    
    <!-- Green bottom right (2/3 width, bottom half) -->
    <path
        android:fillColor="#007E3A"
        android:pathData="M36,54 h72 v54 h-72 z" />
    
    <!-- Rounded corners mask for adaptive icon shape -->
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

</vector>